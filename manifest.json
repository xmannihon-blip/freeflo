{
  "manifest_version": 3,
  "name": "Freeflo",
  "version": "1.0.0",
  "description": "Find contentUrl using Freeflo server.",
  
  "icons": {
    "128": "icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },

  "permissions": ["tabs"],
  "host_permissions": [
    "https://freeflo.onrender.com/*"
  ]
}